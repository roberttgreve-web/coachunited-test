{
  "buildCommand": "",
  "outputDirectory": "public",
  "ignoreCommand": "git log -1 --pretty=%s | grep -q \"^publisher:\"",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/home"
    },
    {
      "source": "/home",
      "destination": "/home.html"
    },
    {
      "source": "/uebungen",
      "destination": "/uebungen.html"
    },
    {
      "source": "/detail",
      "destination": "/detail.html"
    },
    {
      "source": "/uebung/:slug",
      "destination": "/uebung-detail.html"
    },
    {
      "source": "/einheiten",
      "destination": "/einheiten.html"
    },
    {
      "source": "/einheit/:slug",
      "destination": "/einheit-detail.html"
    },
    {
      "source": "/wissen",
      "destination": "/wissen.html"
    },
    {
      "source": "/whatsapp-info",
      "destination": "/whatsapp-info.html"
    },
    {
      "source": "/spenden",
      "destination": "/spenden.html"
    },
    {
      "source": "/ueber-uns",
      "destination": "/ueber-uns.html"
    },
    {
      "source": "/impressum",
      "destination": "/impressum.html"
    },
    {
      "source": "/artikel/:slug",
      "destination": "/artikel-detail.html"
    },
    {
      "source": "/einheit-generator",
      "destination": "/einheit-generator.html"
    },
    {
      "source": "/umgang-mit-ki",
      "destination": "/umgang-mit-ki.html"
    },
    {
      "source": "/uebung-einreichen",
      "destination": "/uebung-einreichen.html"
    },
    {
      "source": "/danke",
      "destination": "/danke.html"
    }
  ]
}
